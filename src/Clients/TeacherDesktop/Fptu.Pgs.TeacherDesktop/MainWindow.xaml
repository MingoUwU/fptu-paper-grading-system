<Window x:Class="Fptu.Pgs.TeacherDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FPTU Paper Grading System"
        Width="1180"
        Height="720"
        MinWidth="960"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6FA">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#14213D">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="FPTU PGS"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,4,0,28"
                               Text="Teacher Desktop"
                               Foreground="#B8C4DD"
                               FontSize="13" />

                    <Button Margin="0,0,0,8" Padding="14,10" HorizontalContentAlignment="Left" Content="Dashboard" />
                    <Button Margin="0,0,0,8" Padding="14,10" HorizontalContentAlignment="Left" Content="Exams &amp; Rubrics" />
                    <Button Margin="0,0,0,8" Padding="14,10" HorizontalContentAlignment="Left" Content="Upload Batch" />
                    <Button Margin="0,0,0,8" Padding="14,10" HorizontalContentAlignment="Left" Content="Review Scores" />
                    <Button Margin="0,0,0,8" Padding="14,10" HorizontalContentAlignment="Left" Content="Reports" />
                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        Padding="12"
                        Background="#20345D"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="API Gateway" Foreground="#B8C4DD" FontSize="11" />
                        <TextBlock Text="http://localhost:5000" Foreground="White" FontSize="12" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel>
                <StackPanel>
                    <TextBlock Text="Batch Grading Dashboard"
                               Foreground="#14213D"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0"
                               Text="Theo dõi pipeline Upload → OCR → AI Suggestion → Teacher Review → Finalize"
                               Foreground="#667085"
                               FontSize="14" />
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        Padding="18,10"
                        VerticalAlignment="Center"
                        Background="#F77F00"
                        Foreground="White"
                        BorderThickness="0"
                        Content="+ Upload batch" />
            </DockPanel>

            <UniformGrid Grid.Row="1" Margin="0,28,0,24" Columns="4">
                <Border Margin="0,0,12,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Uploaded" Foreground="#667085" />
                        <TextBlock Margin="0,8,0,0" Text="0" Foreground="#14213D" FontSize="28" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0,8,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Processing" Foreground="#667085" />
                        <TextBlock Margin="0,8,0,0" Text="0" Foreground="#14213D" FontSize="28" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Margin="8,0,4,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Ready to review" Foreground="#667085" />
                        <TextBlock Margin="0,8,0,0" Text="0" Foreground="#14213D" FontSize="28" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Margin="12,0,0,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Finalized" Foreground="#667085" />
                        <TextBlock Margin="0,8,0,0" Text="0" Foreground="#14213D" FontSize="28" FontWeight="Bold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Padding="22" Background="White" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Recent batches"
                               Foreground="#14213D"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   Text="Chưa có batch nào"
                                   Foreground="#344054"
                                   FontSize="17"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="Upload 5–10 bài mẫu để bắt đầu demo end-to-end."
                                   Foreground="#98A2B3" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
