<Window x:Class="Fptu.Pgs.TeacherDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FPTU Paper Grading System"
        Width="1320"
        Height="820"
        MinWidth="1080"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Background="#F4F6FA">
    <Grid>
        <Grid x:Name="AppShell"
              Visibility="Collapsed">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border x:Name="AdminNavigationShell"
                Grid.Column="0"
                Background="#14213D"
                Visibility="Collapsed">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="FPTU PGS"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,4,0,28"
                               Text="Admin Console"
                               Foreground="#B8C4DD"
                               FontSize="13" />
                    <TextBlock x:Name="CurrentUserTextBlock"
                               Margin="0,0,0,16"
                               Text="Not signed in"
                               Foreground="#D8E2F3"
                               FontSize="12"
                               TextWrapping="Wrap" />

                    <Button x:Name="DashboardButton"
                            Margin="0,0,0,8"
                            Padding="14,10"
                            HorizontalContentAlignment="Left"
                            Tag="Dashboard"
                            Click="Navigate_Click"
                            Content="Dashboard" />
                    <Button x:Name="UsersButton"
                            Margin="0,0,0,8"
                            Padding="14,10"
                            HorizontalContentAlignment="Left"
                            Tag="UserManagement"
                            Click="Navigate_Click"
                            Content="User Management" />
                    <Button x:Name="ExamsRubricsButton"
                            Margin="0,0,0,8"
                            Padding="14,10"
                            HorizontalContentAlignment="Left"
                            Tag="ExamsRubrics"
                            Click="Navigate_Click"
                            Content="Exams &amp; Rubrics" />
                    <Button x:Name="UploadBatchButton"
                            Margin="0,0,0,8"
                            Padding="14,10"
                            HorizontalContentAlignment="Left"
                            Tag="UploadBatch"
                            Click="Navigate_Click"
                            Content="Upload Batch" />
                    <Button x:Name="AssignmentsButton"
                            Margin="0,0,0,8"
                            Padding="14,10"
                            HorizontalContentAlignment="Left"
                            Tag="Assignments"
                            Click="Navigate_Click"
                            Content="Assignments" />
                    <Button x:Name="ReportsButton"
                            Margin="0,0,0,8"
                            Padding="14,10"
                            HorizontalContentAlignment="Left"
                            Tag="Reports"
                            Click="Navigate_Click"
                            Content="Reports" />
                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        Padding="12"
                        Background="#20345D"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="API Gateway" Foreground="#B8C4DD" FontSize="11" />
                        <TextBlock Text="http://localhost:5000" Foreground="White" FontSize="12" />
                        <Button Margin="0,12,0,0"
                                Padding="12,8"
                                HorizontalContentAlignment="Center"
                                Background="#E5E7EB"
                                Foreground="#111827"
                                Click="Logout_Click"
                                Content="Logout" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Border x:Name="TeacherNavigationShell"
                Grid.Column="0"
                Background="#20345D"
                Visibility="Collapsed">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="FPTU PGS"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,4,0,28"
                               Text="Teacher Workspace"
                               Foreground="#C7D3EA"
                               FontSize="13" />
                    <TextBlock x:Name="TeacherCurrentUserTextBlock"
                               Margin="0,0,0,16"
                               Text="Not signed in"
                               Foreground="#E5ECF8"
                               FontSize="12"
                               TextWrapping="Wrap" />

                    <Button x:Name="TeacherDashboardButton"
                            Margin="0,0,0,8"
                            Padding="14,10"
                            HorizontalContentAlignment="Left"
                            Tag="TeacherDashboard"
                            Click="Navigate_Click"
                            Content="My Assignments" />
                    <Button x:Name="ReviewScoresButton"
                            Margin="0,0,0,8"
                            Padding="14,10"
                            HorizontalContentAlignment="Left"
                            Tag="ReviewScores"
                            Click="Navigate_Click"
                            Content="Review Scores" />
                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        Padding="12"
                        Background="#14213D"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Teacher Workspace" Foreground="#B8C4DD" FontSize="11" />
                        <TextBlock Text="Assigned submissions only" Foreground="White" FontSize="12" />
                        <Button Margin="0,12,0,0"
                                Padding="12,8"
                                HorizontalContentAlignment="Center"
                                Background="#E5E7EB"
                                Foreground="#111827"
                                Click="Logout_Click"
                                Content="Logout" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Grid x:Name="DashboardView"
              Grid.Column="1"
              Margin="28"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Dashboard"
                           Foreground="#14213D"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,5,0,0"
                           Text="Tong quan nhanh ve he thong cham bai PE."
                           Foreground="#667085"
                           FontSize="14" />
            </StackPanel>

            <UniformGrid Grid.Row="1" Margin="0,24,0,18" Columns="4">
                <Border Margin="0,0,8,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Pending review" Foreground="#667085" />
                        <TextBlock Text="0"
                                   Margin="0,8,0,0"
                                   Foreground="#14213D"
                                   FontSize="28"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="AI graded" Foreground="#667085" />
                        <TextBlock Text="0"
                                   Margin="0,8,0,0"
                                   Foreground="#14213D"
                                   FontSize="28"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Finalized" Foreground="#667085" />
                        <TextBlock Text="0"
                                   Margin="0,8,0,0"
                                   Foreground="#18794E"
                                   FontSize="28"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Margin="8,0,0,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Gateway" Foreground="#667085" />
                        <TextBlock Text="localhost:5000"
                                   Margin="0,8,0,0"
                                   Foreground="#14213D"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Padding="22" Background="White" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Next step"
                               Foreground="#14213D"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,10,0,0"
                               Text="Man hinh nay se hien thong ke batch, so bai can cham lai, va canh bao quota API."
                               Foreground="#667085"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="UserManagementView"
              Grid.Column="1"
              Margin="28"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel LastChildFill="False">
                <StackPanel>
                    <TextBlock Text="User Management"
                               Foreground="#14213D"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,5,0,0"
                               Text="Create and manage Admin and Teacher accounts."
                               Foreground="#667085"
                               FontSize="14" />
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        Width="110"
                        Margin="0,0,185,0"
                        Padding="16,9"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="RefreshUsers_Click"
                        Content="Refresh" />
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <Border Margin="0,0,10,0"
                        Padding="16"
                        Background="White"
                        CornerRadius="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="UsersGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  HorizontalScrollBarVisibility="Auto"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="210" Header="Full name" Binding="{Binding FullName}" />
                                <DataGridTextColumn Width="220" Header="Email" Binding="{Binding Email}" />
                                <DataGridTextColumn Width="90" Header="Role" Binding="{Binding Role}" />
                                <DataGridTextColumn Width="80" Header="Subject" Binding="{Binding SubjectCode}" />
                                <DataGridCheckBoxColumn Width="85" Header="Active" Binding="{Binding IsActive}" />
                                <DataGridTextColumn Width="140" Header="Last login" Binding="{Binding LastLoginAtUtc, StringFormat=g}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <WrapPanel Grid.Row="1"
                                   Margin="0,14,0,0"
                                   VerticalAlignment="Center">
                            <Button Padding="16,8"
                                    Background="#344054"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Click="ToggleUserStatus_Click"
                                    Content="Enable / Disable" />
                            <TextBlock Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="Select one account before changing its status."
                                       Foreground="#667085" />
                            <TextBlock Margin="18,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="New password"
                                       Foreground="#344054" />
                            <PasswordBox x:Name="ResetUserPasswordBox"
                                         Width="130"
                                         Margin="8,0,0,0"
                                         Padding="8,6" />
                            <Button Margin="8,0,0,0"
                                    Padding="14,8"
                                    Click="ResetUserPassword_Click"
                                    Content="Reset password" />
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Padding="20"
                        Background="White"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Create account"
                                   Foreground="#14213D"
                                   FontSize="18"
                                   FontWeight="SemiBold" />

                        <TextBlock Margin="0,18,0,0" Text="Full name" Foreground="#344054" />
                        <TextBox x:Name="NewUserFullNameTextBox" Margin="0,6,0,0" Padding="10,8" />

                        <TextBlock Margin="0,14,0,0" Text="Email" Foreground="#344054" />
                        <TextBox x:Name="NewUserEmailTextBox" Margin="0,6,0,0" Padding="10,8" />

                        <TextBlock Margin="0,14,0,0" Text="Password" Foreground="#344054" />
                        <PasswordBox x:Name="NewUserPasswordBox" Margin="0,6,0,0" Padding="10,8" />

                        <TextBlock Margin="0,14,0,0" Text="Role" Foreground="#344054" />
                        <ComboBox x:Name="NewUserRoleComboBox"
                                  Margin="0,6,0,0"
                                  Padding="8"
                                  SelectionChanged="NewUserRole_SelectionChanged">
                            <ComboBoxItem Tag="Teacher" Content="Teacher" IsSelected="True" />
                            <ComboBoxItem Tag="Admin" Content="Admin" />
                        </ComboBox>

                        <TextBlock x:Name="NewUserSubjectLabel"
                                   Margin="0,14,0,0"
                                   Text="Subject code"
                                   Foreground="#344054" />
                        <TextBox x:Name="NewUserSubjectTextBox"
                                 Margin="0,6,0,0"
                                 Padding="10,8"
                                 CharacterCasing="Upper" />

                        <Button Margin="0,22,0,0"
                                Padding="16,10"
                                Background="#F77F00"
                                Foreground="White"
                                BorderThickness="0"
                                Click="CreateUser_Click"
                                Content="Create user" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock x:Name="UserManagementMessageTextBlock"
                       Grid.Row="2"
                       Margin="0,14,0,0"
                       Foreground="#667085"
                       Text="User data is managed by Identity Service." />
        </Grid>

        <Grid x:Name="ExamsRubricsView"
              Grid.Column="1"
              Margin="28"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Exams &amp; Rubrics"
                           Foreground="#14213D"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,5,0,0"
                           Text="Quan ly de PE va tieu chi cham diem."
                           Foreground="#667085"
                           FontSize="14" />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,24,0,0"
                    Padding="22"
                    Background="White"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Rubric setup"
                               Foreground="#14213D"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,10,0,18"
                               Text="Sau nay Teacher se nhap rubric/criteria tai day. AI se dua vao cac tieu chi nay de cham bai."
                               Foreground="#667085"
                               FontSize="14"
                               TextWrapping="Wrap" />
                    <DataGrid x:Name="RubricCriteriaGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              MinHeight="280">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="2*" Header="Criterion" />
                            <DataGridTextColumn Width="100" Header="Max score" />
                            <DataGridTextColumn Width="3*" Header="Description" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="UploadBatchView"
              Grid.Column="1"
              Margin="28"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Upload Batch"
                           Foreground="#14213D"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,5,0,0"
                           Text="Upload file DOCX/PDF bai lam de Document Processing tach text, bang va hinh."
                           Foreground="#667085"
                           FontSize="14" />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,24,0,0"
                    Padding="22"
                    Background="White"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Batch input"
                               Foreground="#14213D"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <Border Margin="0,18,0,0"
                            Padding="28"
                            BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            Background="#F9FAFB"
                            CornerRadius="8">
                        <TextBlock Text="Drop file area placeholder - se noi voi Submission Service va Document Processing Service."
                                   Foreground="#667085"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="AssignmentsView"
              Grid.Column="1"
              Margin="28"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Grading Assignments"
                           Foreground="#14213D"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,5,0,0"
                           Text="Assign submissions by subject and workload to teachers."
                           Foreground="#667085"
                           FontSize="14" />
            </StackPanel>

            <UniformGrid Grid.Row="1" Margin="0,24,0,18" Columns="3">
                <Border Margin="0,0,8,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Unassigned" Foreground="#667085" />
                        <TextBlock Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Foreground="#B54708" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Assigned" Foreground="#667085" />
                        <TextBlock Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Foreground="#14213D" />
                    </StackPanel>
                </Border>
                <Border Margin="8,0,0,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Completed" Foreground="#667085" />
                        <TextBlock Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Foreground="#18794E" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Padding="22" Background="White" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Assignment management"
                               Foreground="#14213D"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,10,0,18"
                               Text="Select an exam batch, filter teachers by subject, then distribute submissions equally or assign them manually."
                               Foreground="#667085"
                               TextWrapping="Wrap" />
                    <Button Width="190"
                            Padding="16,10"
                            HorizontalAlignment="Left"
                            Background="#F77F00"
                            Foreground="White"
                            BorderThickness="0"
                            IsEnabled="False"
                            Content="Create assignment" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ReportsView"
              Grid.Column="1"
              Margin="28"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Reports"
                           Foreground="#14213D"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,5,0,0"
                           Text="Bao cao diem, audit log va export."
                           Foreground="#667085"
                           FontSize="14" />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,24,0,0"
                    Padding="22"
                    Background="White"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Report center"
                               Foreground="#14213D"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,10,0,0"
                               Text="Sau nay man hinh nay dung de xem do lech AI/Teacher, export Excel/PDF va tra cuu audit log."
                               Foreground="#667085"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="TeacherDashboardView"
              Grid.Column="1"
              Margin="28"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="My Assignments"
                           Foreground="#14213D"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,5,0,0"
                           Text="Only submissions assigned to this teacher are shown here."
                           Foreground="#667085"
                           FontSize="14" />
            </StackPanel>

            <UniformGrid Grid.Row="1" Margin="0,24,0,18" Columns="3">
                <Border Margin="0,0,8,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Waiting" Foreground="#667085" />
                        <TextBlock Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Foreground="#B54708" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="In progress" Foreground="#667085" />
                        <TextBlock Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Foreground="#14213D" />
                    </StackPanel>
                </Border>
                <Border Margin="8,0,0,0" Padding="18" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Completed" Foreground="#667085" />
                        <TextBlock Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Foreground="#18794E" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Padding="22" Background="White" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Assigned submissions"
                               Foreground="#14213D"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,10,0,18"
                               Text="Choose an assigned submission and open the review workspace to verify the AI score."
                               Foreground="#667085"
                               TextWrapping="Wrap" />
                    <Button Width="190"
                            Padding="16,10"
                            HorizontalAlignment="Left"
                            Background="#F77F00"
                            Foreground="White"
                            BorderThickness="0"
                            Tag="ReviewScores"
                            Click="Navigate_Click"
                            Content="Open review workspace" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ReviewScoresView"
              Grid.Column="1"
              Margin="28"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel>
                <StackPanel>
                    <TextBlock Text="Teacher Re-grading"
                               Foreground="#14213D"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,5,0,0"
                               Text="AI chấm vòng đầu. Teacher kiểm tra từng tiêu chí và quyết định điểm chính thức."
                               Foreground="#667085"
                               FontSize="14" />
                </StackPanel>
                <Border DockPanel.Dock="Right"
                        Padding="12,7"
                        VerticalAlignment="Center"
                        Background="#E9F7EF"
                        CornerRadius="16">
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Chưa tải bài"
                               Foreground="#18794E"
                               FontWeight="SemiBold" />
                </Border>
            </DockPanel>

            <Expander Grid.Row="1"
                      Margin="0,18,0,0"
                      Background="White"
                      IsExpanded="False">
                <Expander.Header>
                    <DockPanel Width="1040">
                        <TextBlock Text="Gemini API cá nhân (BYOK)"
                                   Foreground="#14213D"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="ApiKeyStatusTextBlock"
                                   DockPanel.Dock="Right"
                                   Text="Đang kiểm tra..."
                                   Foreground="#667085" />
                    </DockPanel>
                </Expander.Header>
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               Text="Gemini API Key"
                               Foreground="#344054"
                               FontWeight="SemiBold" />
                    <PasswordBox x:Name="PersonalApiKeyPasswordBox"
                                 Grid.Column="1"
                                 Padding="10,8"
                                 MinWidth="360" />
                    <Button Grid.Column="2"
                            Margin="12,0,0,0"
                            Padding="16,8"
                            Background="#14213D"
                            Foreground="White"
                            BorderThickness="0"
                            Click="SaveApiKey_Click"
                            Content="Lưu key" />
                    <Button Grid.Column="3"
                            Margin="8,0,0,0"
                            Padding="16,8"
                            Click="TestApiKey_Click"
                            Content="Kiểm tra" />
                    <Button Grid.Column="4"
                            Margin="8,0,0,0"
                            Padding="16,8"
                            Foreground="Firebrick"
                            Click="DeleteApiKey_Click"
                            Content="Xóa" />

                    <CheckBox x:Name="AllowSystemFallbackCheckBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Grid.ColumnSpan="4"
                              Margin="0,10,0,0"
                              IsChecked="True"
                              Content="Nếu key cá nhân hết quota hoặc lỗi, cho phép dùng API key hệ thống" />
                </Grid>
            </Expander>

            <Border Grid.Row="2"
                    Margin="0,22,0,18"
                    Padding="16"
                    Background="White"
                    CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               Text="Submission ID"
                               Foreground="#344054"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="SubmissionIdTextBox"
                             Grid.Column="1"
                             Padding="10,8"
                             VerticalContentAlignment="Center"
                             Text="00000000-0000-0000-0000-000000000000" />
                    <Button Grid.Column="2"
                            Margin="12,0,0,0"
                            Padding="20,9"
                            Background="#14213D"
                            Foreground="White"
                            BorderThickness="0"
                            Click="LoadScore_Click"
                            Content="Tải kết quả AI" />
                </Grid>
            </Border>

            <UniformGrid Grid.Row="3" Margin="0,0,0,18" Columns="4">
                <Border Margin="0,0,8,0" Padding="16" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="AI Score" Foreground="#667085" />
                        <TextBlock x:Name="AiScoreTextBlock"
                                   Margin="0,6,0,0"
                                   Text="—"
                                   Foreground="#14213D"
                                   FontSize="25"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="AiCredentialSourceTextBlock"
                                   Margin="0,4,0,0"
                                   Text="API: —"
                                   Foreground="#98A2B3"
                                   FontSize="11" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0" Padding="16" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Teacher Score" Foreground="#667085" />
                        <TextBlock x:Name="TeacherScoreTextBlock"
                                   Margin="0,6,0,0"
                                   Text="—"
                                   Foreground="#14213D"
                                   FontSize="25"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0" Padding="16" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Difference" Foreground="#667085" />
                        <TextBlock x:Name="DifferenceTextBlock"
                                   Margin="0,6,0,0"
                                   Text="—"
                                   Foreground="#F77F00"
                                   FontSize="25"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Margin="8,0,0,0" Padding="16" Background="White" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Final Score" Foreground="#667085" />
                        <TextBlock x:Name="FinalScoreTextBlock"
                                   Margin="0,6,0,0"
                                   Text="—"
                                   Foreground="#18794E"
                                   FontSize="25"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Margin="0,0,10,0" Padding="16" Background="White" CornerRadius="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Margin="0,0,0,12"
                                   Text="Điểm theo rubric"
                                   Foreground="#14213D"
                                   FontSize="17"
                                   FontWeight="SemiBold" />
                        <DataGrid x:Name="CriteriaGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="2*"
                                                    Header="Criterion"
                                                    IsReadOnly="True"
                                                    Binding="{Binding CriterionName}" />
                                <DataGridTextColumn Width="70"
                                                    Header="Max"
                                                    IsReadOnly="True"
                                                    Binding="{Binding MaxScore, StringFormat=0.##}" />
                                <DataGridTextColumn Width="80"
                                                    Header="AI"
                                                    IsReadOnly="True"
                                                    Binding="{Binding AiScore, StringFormat=0.##}" />
                                <DataGridTextColumn Width="90"
                                                    Header="Teacher"
                                                    Binding="{Binding TeacherScore, UpdateSourceTrigger=LostFocus}" />
                                <DataGridTextColumn Width="2*"
                                                    Header="Teacher feedback"
                                                    Binding="{Binding TeacherFeedback, UpdateSourceTrigger=LostFocus}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Padding="16"
                        Background="White"
                        CornerRadius="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="AI feedback"
                                   Foreground="#14213D"
                                   FontWeight="SemiBold" />
                        <TextBox x:Name="AiFeedbackTextBox"
                                 Grid.Row="1"
                                 Margin="0,8,0,16"
                                 Padding="10"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                        <TextBlock Grid.Row="2"
                                   Text="Teacher feedback"
                                   Foreground="#14213D"
                                   FontWeight="SemiBold" />
                        <TextBox x:Name="TeacherFeedbackTextBox"
                                 Grid.Row="3"
                                 Margin="0,8,0,0"
                                 Padding="10"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </Border>
            </Grid>

            <DockPanel Grid.Row="5" Margin="0,18,0,0">
                <TextBlock x:Name="MessageTextBlock"
                           VerticalAlignment="Center"
                           Foreground="#667085"
                           Text="Nhập Submission ID để bắt đầu review." />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Margin="0,0,10,0"
                            Padding="18,10"
                            Background="#344054"
                            Foreground="White"
                            BorderThickness="0"
                            Click="SaveTeacherGrade_Click"
                            Content="Lưu điểm Teacher" />
                    <Button Padding="18,10"
                            Background="#F77F00"
                            Foreground="White"
                            BorderThickness="0"
                            Click="FinalizeScore_Click"
                            Content="Finalize điểm" />
                </StackPanel>
            </DockPanel>
        </Grid>
        </Grid>

        <Border x:Name="LoginView"
                Background="#F4F6FA">
            <Grid>
                <Border Width="430"
                        Padding="30"
                        Background="White"
                        CornerRadius="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="FPTU PGS"
                                   Foreground="#14213D"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   TextAlignment="Center" />
                        <TextBlock Margin="0,6,0,28"
                                   Text="Login to Paper Grading System"
                                   Foreground="#667085"
                                   FontSize="14"
                                   TextAlignment="Center" />

                        <TextBlock Text="Email"
                                   Foreground="#344054"
                                   FontWeight="SemiBold" />
                        <TextBox x:Name="LoginEmailTextBox"
                                 Margin="0,6,0,16"
                                 Padding="12,9"
                                 Text="teacher.swt@fptu.edu.vn" />

                        <TextBlock Text="Password"
                                   Foreground="#344054"
                                   FontWeight="SemiBold" />
                        <PasswordBox x:Name="LoginPasswordBox"
                                     Margin="0,6,0,10"
                                     Padding="12,9"
                                     Password="Teacher@123" />

                        <TextBlock Text="Seed users: admin@fptu.edu.vn / Admin@123, teacher.swt@fptu.edu.vn / Teacher@123"
                                   Foreground="#98A2B3"
                                   FontSize="11"
                                   TextWrapping="Wrap" />

                        <Button Margin="0,24,0,0"
                                Padding="16,11"
                                Background="#F77F00"
                                Foreground="White"
                                BorderThickness="0"
                                Click="Login_Click"
                                Content="Login" />
                        <TextBlock x:Name="LoginMessageTextBlock"
                                   Margin="0,14,0,0"
                                   Foreground="Firebrick"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,16,16,0"
                Padding="10,6"
                Background="#EEF2F7"
                CornerRadius="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="LanguageLabelTextBlock"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Text="Language"
                           Foreground="#344054"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <ComboBox x:Name="LanguageComboBox"
                          Width="72"
                          SelectionChanged="LanguageComboBox_SelectionChanged">
                    <ComboBoxItem Tag="vi" Content="VI" />
                    <ComboBoxItem Tag="en" Content="EN" />
                </ComboBox>
            </StackPanel>
        </Border>
    </Grid>
</Window>
